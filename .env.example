# Named stores (JSON). The zero-infra "local" filesystem store always exists.
# OBJECTSTORE_STORES={"media": {"backend": "s3", "bucket": "media-prod", "profile": "prod"}, "minio": {"backend": "s3", "endpoint": "http://minio.arpa:9000"}, "reports": {"backend": "gcs", "bucket": "acme-reports"}, "archive": {"backend": "azure", "bucket": "archive"}}
# OBJECTSTORE_DEFAULT_STORE=local
# OBJECTSTORE_FS_ROOT=~/.local/share/objectstore-mcp

# Safety limits (bytes / keys)
# OBJECTSTORE_MAX_GET_BYTES=10485760
# OBJECTSTORE_MAX_PUT_BYTES=10485760
# OBJECTSTORE_MAX_TRANSFER_BYTES=104857600
# OBJECTSTORE_MAX_BATCH_KEYS=100
# OBJECTSTORE_MAX_LIST_KEYS=1000
# OBJECTSTORE_ALLOW_DELETE=true
# OBJECTSTORE_ALLOW_BUCKET_DELETE=false

# Provider credentials resolve through each SDK's own chain:
# AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY= / AWS_PROFILE=  (boto3 chain)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# AZURE_STORAGE_CONNECTION_STRING=
